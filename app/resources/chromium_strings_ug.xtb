<!DOCTYPE translationbundle>
<translationbundle lang="ug">
<translation id="2238104961394611930">ئوچۇق • بۇ كېڭەيتمىنىڭ مەنبەسى دەلىللەنمىگەن.</translation>
<translation id="259482898795437589">{NUM_EXTENSIONS,plural, =1{ئۇنى چىقىرىۋېتىش تەۋسىيە قىلىنىدۇ.}other {چىقىرىۋېتىش تەۋسىيە قىلىنىدۇ.}}</translation>
<translation id="6885534934768077023">ئاگاھلاندۇرۇش: كېڭەيتمىنىڭ تور كۆرۈش پائالىيىتىڭىزنى خاتىرىلىشىنى تور كۆرگۈچ توسالمايدۇ. ئىزسىز ھالەتتە بۇ كېڭەيتمىنى ئىشلەتمەسلىك ئۈچۈن بۇ تاللانمىنى ئېتىپ قويۇڭ.</translation>
<translation id="7597668698051545254">ئېتىك • بۇ كېڭەيتمىنىڭ مەنبەسى دەلىللەنمىگەن.</translation>
</translationbundle>