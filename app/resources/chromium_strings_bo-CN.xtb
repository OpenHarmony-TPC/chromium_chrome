<!DOCTYPE translationbundle>
<translationbundle lang="bo-CN">
<translation id="2238104961394611930">ཁ་ཕྱེ་ཟིན། • རྒྱ་སྐྱེད་བྱ་རིམ་འདིའི་འབྱུང་ཁུངས་ར་སྤྲོད་མི་ཐུབ།</translation>
<translation id="2340553376566028509">ཁ་ཕྱེ་ཟིན། • རྒྱ་སྐྱེད་བྱ་རིམ་འདིའི་འབྱུང་ཁུངས་ར་སྤྲོད་མི་ཐུབ།</translation>
<translation id="259482898795437589">{NUM_EXTENSIONS,plural, =1{ཁྱེད་ཀྱིས་དེ་སྤོ་འབུད་བྱས་ན་ལེགས།}other {དེ་དག་སྤོ་འབུད་གནང་ན་ལེགས།}}</translation>
<translation id="3467729044755133349">ཁ་བརྒྱབ་ཟིན། • རྒྱ་སྐྱེད་བྱ་རིམ་འདིའི་འབྱུང་ཁུངས་ར་སྤྲོད་མི་ཐུབ།</translation>
<translation id="6885534934768077023">ཉེན་བརྡ། བཤར་ཆས་ཀྱིས་རྒྱ་སྐྱེད་བྱ་རིམ་གྱིས་ཁྱེད་ཀྱི་བཤར་ལྟའི་བྱ་འགུལ་ཟིན་ཐོར་འགོད་པར་བཀག་འགོག་བྱེད་མི་ཐུབ། ཤུལ་མེད་རྣམ་པའི་སྐབས་སུ། རྒྱ་སྐྱེད་བྱ་རིམ་དེ་བཀོལ་མཚམས་འཇོག་དགོས་ན། བདམས་པ་འདི་འདོར་དགོས།</translation>
<translation id="7597668698051545254">ཁ་བརྒྱབ་ཟིན། • རྒྱ་སྐྱེད་བྱ་རིམ་འདིའི་འབྱུང་ཁུངས་ར་སྤྲོད་མི་ཐུབ།</translation>
</translationbundle>