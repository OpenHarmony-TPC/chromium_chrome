<?xml version="1.0" ?>
<!DOCTYPE translationbundle>
<translationbundle lang="bo-CN">
<translation id="1004218526896219317">ལྟ་སྤྱོད་བྱེད་དབང་ཡོད་པའི་དྲ་ཚུགས།</translation>
<translation id="1098777419082098167">ཁྱེད་ཀྱི་ཐོ་འཇུག་མྱོང་བའི་སྒྲིག་ཆས་ཚང་མའི་ཐོག་གི་བཤར་ལྟའི་ཟིན་ཐོ་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱེད་པ།</translation>
<translation id="1165039591588034296">ནོར་བ།</translation>
<translation id="1181037720776840403">སྤོ་འབུད།</translation>
<translation id="1195805062734778374">གསར་སྤེལ་བྱེད་མཁན་གྱི་རྣམ་པ་ཁ་ཕྱེ་ན། ཕྱོགས་གསུམ་པའི་རྒྱ་སྐྱེད་བྱ་རིམ་སྒྲིག་འཇུག་དང་དོ་དམ་བྱ་ཆོག རྒྱ་སྐྱེད་བྱ་རིམ་འདི་དག་ལ་བདེ་འཇགས་ཞིབ་དཔྱད་ཚད་ལེན་མ་བརྒྱུད་པས། ཉེན་ཁ་ཡོད་ཀྱང་སྲིད། ཁ་ཕྱེ་བ་གཏན་འཁེལ་ཡིན་ནམ།</translation>
<translation id="119944043368869598">ཚང་མ་གཙང་སེལ།</translation>
<translation id="1407865659932107504">ཁྱེད་ཀྱི་བརྙན་ཡོལ་ཐོག་གི་ནང་དོན་གཅོད་ལེན་བྱེད་པ</translation>
<translation id="1600857548979126453">ཤོག་ངོས་སྐྱོན་སེལ་བྱ་རིམ་ཀྱི་རྒྱབ་སྣེར་ལྟ་སྤྱོད་བྱེད་པ།</translation>
<translation id="1616206807336925449">རྒྱ་སྐྱེད་བྱ་རིམ་འདིར་དམིགས་བསལ་དབང་ཚད་གང་ཡང་མི་དགོས།</translation>
<translation id="1838374766361614909">བཤེར་འཚོལ་ཡི་གེ་གཙང་སེལ།</translation>
<translation id="1928696683969751773">གསར་སྒྱུར།</translation>
<translation id="1942128823046546853">དྲ་ཚུགས་ཚང་མའི་ཐོག་གི་ཁྱེད་ཀྱི་གཞི་གྲངས་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱེད་པ།</translation>
<translation id="2025632980034333559">༼<ph name="APP_NAME" />༽འཕྲོ་བརླག་ཕྱིན་འདུག ཆ་འཕྲིན་སྒྲོམ་འདིར་བརྡབས་ནས། རྒྱ་སྐྱེད་བྱ་རིམ་དེ་ཡང་བསྐྱར་སྣོན་འཇུག་གནང་རོགས།།</translation>
<translation id="2079825939263178885">ཁྱེད་ཀྱི་བཤར་ལྟའི་གཞི་གྲངས་ལ་ལྟ་སྤྱོད་དང་ཚོད་འཛིན་བྱེད་པ་སྟེ། བཤར་ལྟའི་ལོ་རྒྱུས་དང་། ཕབ་ལེན་གྱི་ལོ་རྒྱུས། Cookie རེའུ་མིག་གཞི་གྲངས། གསང་ཨང་སོགས་ཚུད་ཡོད།</translation>
<translation id="2101982145804934852">རྒྱ་སྐྱེད་བྱ་རིམ་འདིས་ཁྱེད་ཀྱི་ལྟ་སྤྱོད་བྱ་ཡུལ་གྱི་དྲ་ཚུགས་ཐོག་གི་གཞི་གྲངས་ཚང་མ་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱ་ཆོག་པར་བྱེད།</translation>
<translation id="2180620921879609685">ཤོག་ངོས་ཚང་མའི་ནང་དོན་འགོག་པ།</translation>
<translation id="2207116775853792104">རྒྱ་སྐྱེད་བྱ་རིམ་འདི་ཉར་འཇོག</translation>
<translation id="2350133097354918058">ཡང་བསྐྱར་སྣོན་འཇུག་བྱས་ཟིན།</translation>
<translation id="2480868415629598489">ཁྱེད་ཀྱི་འདྲ་བཤུ་དང་སྦྱར་བའི་གཞི་གྲངས་བཟོ་བཅོས་བྱེད་པ།</translation>
<translation id="2616366145935564096"><ph name="WEBSITE_1" />ཐོག་གི་ཁྱེད་ཀྱི་གཞི་གྲངས་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱེད།</translation>
<translation id="2673135533890720193">ཁྱེད་ཀྱི་བཤར་ལྟའི་ཟིན་ཐོ་ཀློག་ལེན་བྱེད་པ།</translation>
<translation id="2739240477418971307">ཁྱེད་ཀྱི་འགལ་རྐྱེན་མེད་པའི་སྒྲིག་འགོད་བཟོ་བཅོས་བྱེད་པ།</translation>
<translation id="2835761321523638096">དཔེ་ཀློག་གསལ་ཐོའི་ཁྲོད་ཀྱི་དཀར་ཆག་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱེད་པ།</translation>
<translation id="2870560284913253234">དྲ་ཚུགས།</translation>
<translation id="2916745397441987255">རྒྱ་སྐྱེད་བྱ་རིམ་བཤེར་འཚོལ།</translation>
<translation id="3097016124663043290">འདོར་བ།</translation>
<translation id="3280172912113104877">རྒྱ་སྐྱེད་བྱ་རིམ་འདིར་དྲ་ཚུགས་གཞན་པར་ལྟ་སྤྱོད་བྱེད་དབང་མེད།</translation>
<translation id="330270904988027475">མཉམ་ལས་བྱ་ཡུལ་དུ་གྱུར་བའི་གདོད་མའི་ཉེར་སྤྱོད་ཀྱིས་རེ་ཞུ་བྱེད་སྐབས་སྟེགས་རྒྱབ་ཏུ་འཁོར་སྐྱོད་བྱེད།</translation>
<translation id="3341703758641437857">ཡིག་ཆའི་དྲ་ཚིགས་ལ་ལྟ་སྤྱོད་བྱ་ཆོག་པར་བྱེད།</translation>
<translation id="3555812735919707620">རྒྱ་སྐྱེད་བྱ་རིམ་བཤིག་ཕབ།</translation>
<translation id="3654045516529121250">ཁྱེད་ཀྱི་འགལ་རྐྱེན་མེད་པའི་སྒྲིག་འགོད་ཀློག་ལེན་བྱེད་པ།</translation>
<translation id="3798449238516105146">པར་གཞི།</translation>
<translation id="3838085852053358637">རྒྱ་སྐྱེད་བྱ་རིམ་སྣོན་འཇུག་བྱེད་མ་ཐུབ།</translation>
<translation id="3866249974567520381">གསལ་བཤད།</translation>
<translation id="3893536212201235195">ཁྱེད་ཀྱི་འགལ་རྐྱེན་མེད་པའི་སྒྲིག་འགོད་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱེད་པ།</translation>
<translation id="3903882377278268878">ཁྱེད་ཀྱི་བཤར་ཆས་ཁྲོད་ཀྱི་ Cookies ལ་ལྟ་སྤྱོད་དང་སྒྲིག་བཀོལ་བྱ།</translation>
<translation id="3970114302595058915">ID</translation>
<translation id="399788104667917863">ལག་ཆའི་ཚན་བྱང་ལ་གཏན་འཇགས།</translation>
<translation id="407173827865827707">རྡེབ་སྐབས།</translation>
<translation id="4107048419833779140">གསོག་ཆས་ངོས་འཛིན་དང་འཕར་ཐོན།</translation>
<translation id="4165986682804962316">དྲ་ཚུགས་སྒྲིག་འགོད།</translation>
<translation id="4186370088425159562">མཉམ་ལས་བྱེད་པའི་འཕྲུལ་ཆས་འདིའི་ཉེར་སྤྱོད་དང་འཕྲིན་གཏོང་བ།</translation>
<translation id="4194329256130969655">ཤུལ་མེད་རྣམ་པའི་སྐབས་སུ་སྤྱོད་འགོ་འཛུགས།</translation>
<translation id="4225397296022057997">དྲ་ཚུགས་ཚང་མའི་ཐོག</translation>
<translation id="4348766275249686434">ནོར་འཁྲུལ་ཁག་བསྡུ་རུབ།</translation>
<translation id="4364830672918311045">བརྡ་ཐོ་མངོན་སྟོན།</translation>
<translation id="4375035964737468845">ཕབ་ལེན་བྱས་ཟིན་པའི་ཡིག་ཆ་ཁ་འབྱེད།</translation>
<translation id="4522570452068850558">གནས་ཚུལ་ཞིབ་ཕྲ།</translation>
<translation id="4564150883622494122">རྒྱ་སྐྱེད་བྱ་རིམ་ཚང་མ།</translation>
<translation id="4617270414136722281">རྒྱ་སྐྱེད་བྱ་རིམ་གྱི་གདམ་ཀ</translation>
<translation id="477727212864867766">ཁྱེད་ཀྱི་གློག་ཡིག་ས་གནས་ལེན་པ།</translation>
<translation id="5235750401727657667">ཁྱེད་ཀྱིས་རྟགས་བྱང་ཤོག་ངོས་གསར་པ་ཁ་འབྱེད་སྐབས་མཐོང་བའི་ཤོག་ངོས་ཚབ་བརྗེ་བྱ།</translation>
<translation id="5244466461749935369">སྐབས་འཕྲལ་ཉར་འཇོག</translation>
<translation id="5299558715747014286">ཁྱེད་ཀྱི་རྟགས་བྱང་ཤོག་ངོས་ཚོ་ཆུང་ལ་ལྟ་ཞིབ་དང་དོ་དམ་བྱེད་པ།</translation>
<translation id="5313967007315987356">དྲ་ཚུགས་སྣོན་པ།</translation>
<translation id="5414566801737831689">ཁྱེད་ཀྱིས་ལྟ་སྤྱོད་བྱས་ཟིན་པའི་དྲ་ཚུགས་ཀྱི་བབ་མཚུངས་རིས་རྟགས་ཀློག་ལེན་བྱེད་པ།</translation>
<translation id="5548606607480005320">བདེ་འཇགས་ཞིབ་བཤེར།</translation>
<translation id="5556459405103347317">ཡང་བསྐྱར་སྣོན་འཇུག</translation>
<translation id="5707185214361380026">གཤམ་གསལ་འབྱུང་ཁུངས་ཡིན་པའི་རྒྱ་སྐྱེད་བྱ་རིམ་སྣོན་འཇུག་བྱེད་མི་ཐུབ།</translation>
<translation id="5804241973901381774">དབང་ཚད།</translation>
<translation id="5916664084637901428">ཁ་ཕྱེ་ཡོད།</translation>
<translation id="6341850831632289108">ཁྱེད་རང་གནས་སའི་ས་ཁམས་གནས་ཡུལ་ལ་ཞིབ་དཔྱད་བྱེད་པ།</translation>
<translation id="6370021412472292592">གསལ་ཐོ་སྣོན་འཇུག་བྱེད་མི་ཐུབ།</translation>
<translation id="6384275966486438344">ཁྱེད་ཀྱི་བཤེར་འཚོལ་སྒྲིག་འགོད་འདི་ལ་བཅོས་རྒྱུ་སྟེ། <ph name="SEARCH_HOST" /></translation>
<translation id="6408118934673775994"><ph name="WEBSITE_1" />དང་<ph name="WEBSITE_2" />དང་<ph name="WEBSITE_3" />ཐོག་གི་ཁྱེད་ཀྱི་གཞི་གྲངས་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱེད།</translation>
<translation id="6450876761651513209">ཁྱེད་ཀྱི་སྒེར་གསང་གི་འབྲེལ་ཡོད་སྒྲིག་འགོད་བཟོ་བཅོས་བྱེད་པ།</translation>
<translation id="6455264371803474013">དམིགས་བཙུགས་དྲ་ཚུགས་ཐོག</translation>
<translation id="6655190889273724601">གསར་སྤེལ་མཁན་གྱི་རྣམ་པ།</translation>
<translation id="6698810901424468597"><ph name="WEBSITE_1" />དང་<ph name="WEBSITE_2" />ཐོག་གི་ཁྱེད་ཀྱི་གཞི་གྲངས་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱེད།</translation>
<translation id="6786747875388722282">རྒྱ་སྐྱེད་བྱ་རིམ།</translation>
<translation id="6841186874966388268">ནོར་བ།</translation>
<translation id="6965382102122355670">གཏན་འཁེལ།</translation>
<translation id="7017219178341817193">དྲ་ངོས་གསར་པ་སྣོན་པ།།</translation>
<translation id="7144878232160441200">ཡང་བསྐྱར་ཚོད་ལྟ།</translation>
<translation id="7154130902455071009">ཁྱེད་ཀྱི་ཐོག་མའི་ཤོག་ངོས་འདི་ལ་བཅོས་རྒྱུ་སྟེ། <ph name="START_PAGE" /></translation>
<translation id="7257666756905341374">ཁྱེད་ཀྱི་འདྲ་བཤུ་དང་སྦྱར་བའི་གཞི་གྲངས་ཀློག་ལེན་བྱེད་པ།</translation>
<translation id="730515362922783851">རང་གནས་དྲ་རྒྱ་དང་མཉམ་སྦྲེལ་དྲ་རྒྱའི་ཁྲོད་ཀྱི་སྒྲིག་ཆས་གང་རུང་དང་གཞི་གྲངས་བརྗེ་རེས་བྱེད་པ།</translation>
<translation id="7307138455910007225">ཁྱེད་ཀྱི་རང་གནས་དྲ་རྒྱའི་ཐོག་གི་སྒྲིག་ཆས་འཚོལ་བ་སྟེ། དཔེར་ན། པར་འདེབས་འཕྲུལ་ཆས་ལྟ་བུ།</translation>
<translation id="746861123368584540">རྒྱ་སྐྱེད་བྱ་རིམ་སྣོན་འཇུག་བྱས་ཟིན།</translation>
<translation id="7658239707568436148">འདོར་བ།</translation>
<translation id="7819259957768717567">དྲ་ཚུགས་ཁག་ཅིག་ཐོག་གི་ཁྱེད་ཀྱི་གཞི་གྲངས་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱེད་པ།</translation>
<translation id="7876243839304621966">ཚང་མ་སུབ་པ།</translation>
<translation id="7968742106503422125">ཁྱེད་ཀྱི་འདྲ་བཤུ་དང་སྦྱར་བའི་གཞི་གྲངས་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱེད་པ།</translation>
<translation id="8028993641010258682">ཆེ་ཆུང་།</translation>
<translation id="8037117027592400564">འདྲེས་སྦྱོར་སྐད་གདངས་བཀོལ་ནས་བཤད་པའི་ཡི་གེ་ཚང་མ་ཀློག་ལེན་བྱེད་པ།</translation>
<translation id="803771048473350947">ཡིག་ཆ།</translation>
<translation id="8090234456044969073">ཁྱེད་ཀྱིས་རྒྱུན་དུ་ལྟ་སྤྱོད་བྱེད་ཚད་མང་ཤོས་ཀྱི་དྲ་ཚུགས་ཀྱི་རེའུ་མིག་ཀློག་ལེན་བྱེད་པ།</translation>
<translation id="8118860139461251237">ཁྱེད་ཀྱི་ཕབ་ལེན་ནང་དོན་དོ་དམ་བྱེད་པ།</translation>
<translation id="8144708707828713989">ཁྱེད་ཀྱི་གཤམ་གསལ་དབང་ཚད་ཚོད་འཛིན་གྱི་སྒྲིག་འགོད་བཟོ་བཅོས་བྱ་རྒྱུ་སྟེ། དྲ་ཚུགས་ཀྱི་ Cookie དང་ JavaScript དང་བར་གཞུག ས་ཁམས་གནས་ཡུལ་གྱི་ཆ་འཕྲིན། སྐད་སྦུག བརྙན་མིག་སོགས་ཀྱི་རྩོལ་ནུས་ཀྱི་བཀོལ་སྤྱོད་དབང་ཚད་བཅས།</translation>
<translation id="8191230140820435481">ཁྱེད་ཀྱི་ཉེར་སྤྱོད་དང་། རྒྱ་སྐྱེད་བྱ་རིམ། བརྗོད་གཞིའི་རྒྱབ་ལྗོངས་བཅས་ལ་དོ་དམ་བྱེད་པ།</translation>
<translation id="8241868517363889229">ཁྱེད་ཀྱི་དཔེ་འཛར་ཀློག་ལེན་དང་བཟོ་བཅོས་བྱེད་པ།</translation>
<translation id="8284279544186306258">དྲ་ཚིགས་ <ph name="WEBSITE_1" /> ཡོད་ཚད།</translation>
<translation id="8294282569826134620">ཁྱེད་ཀྱི་ཐོ་འཇུག་མྱོང་བའི་སྒྲིག་ཆས་ཚང་མའི་ཐོག་གི་བཤར་ལྟའི་ཟིན་ཐོ་ཀློག་ལེན་བྱེད་པ།</translation>
<translation id="8339542793910400648">བཤིག་འགྲོལ་བྱས་ཟིན་པའི་རྒྱ་སྐྱེད་བྱ་རིམ་སྣོན་འཇུག་བྱེད།</translation>
<translation id="8351835748080111909">རྒྱ་སྐྱེད་བྱ་རིམ།</translation>
<translation id="8353683614194668312">གོ་རིམ་དེ་ཡིན་ཆོག་པ་ནི།</translation>
<translation id="8662911384982557515">ཁྱེད་ཀྱི་གཙོ་ངོས་འདི་ལ་བཅོས་རྒྱུ་སྟེ། <ph name="HOME_PAGE" /></translation>
<translation id="8712637175834984815">ཤེས་སོང་།</translation>
<translation id="8775144690796719618">དྲ་ཚིགས་ནུས་མེད་ཡིན།</translation>
<translation id="9065203028668620118">བཟོ་བཅོས།</translation>
</translationbundle>