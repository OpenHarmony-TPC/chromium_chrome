               <policyitem type="compatibility" name="APPLE2" path=".*" desc="" />
               <policyitem type="compatibility" name="MPL 1.1.1" path=".*" desc="" />

                
            </policy>
        </policylist>
        <filefilterlist>
            <filefilter name="defaultPolicyFilter"
                desc="Filters for compatibility,license header policies">
                <filteritem type="filepath" name="test/data/dromaeo.*js" desc="" />
                <filteritem type="filepath" name=".*chromium" desc="" />
